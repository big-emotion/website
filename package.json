{
  "name": "big-emotion",
  "version": "0.7.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:storybook": "vitest run --config vitest.storybook.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "slicemachine": "node --env-file-if-exists=.env scripts/gen-slicemachine-config.mjs && start-slicemachine",
    "prismic:codegen": "prismic-ts-codegen",
    "prismic:check": "node --env-file-if-exists=.env scripts/prismic-check.mjs",
    "prismic:check-display": "node --env-file-if-exists=.env scripts/prismic-check-display.mjs",
    "prismic:pull": "node --env-file-if-exists=.env scripts/prismic-pull.mjs",
    "prismic:push": "node --env-file-if-exists=.env scripts/prismic-push.mjs",
    "prismic:seed-cases": "node --env-file-if-exists=.env scripts/seed-case-studies.mjs",
    "prismic:seed-home": "node --env-file-if-exists=.env scripts/seed-home.mjs"
  },
  "dependencies": {
    "@prismicio/client": "^7.21.8",
    "@prismicio/next": "^2.2.4",
    "@prismicio/react": "^3.4.1",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "next": "16.2.9",
    "next-intl": "4.13.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "three": "0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource/bbh-sans-bartle": "^5.3.0",
    "@fontsource/bbh-sans-bogle": "^5.3.0",
    "@fontsource/bbh-sans-hegarty": "^5.3.0",
    "@slicemachine/adapter-next": "^0.3.96",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/nextjs": "^10.5.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prismic-ts-codegen": "^0.1.30",
    "slice-machine-ui": "^2.21.3",
    "storybook": "^10.5.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
