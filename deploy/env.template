# Next.js runtime — copy to .env on the VPS (chmod 600, never commit).
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Transactional mail via Microsoft Graph (src/lib/mail.ts) — the one send path
# shared by magic-link sign-in, support escalations, and the contact relay.
# MAIL_SENDER is the default/portal sending mailbox (espace@); the contact
# relay overrides it per call to send as hello@big-emotion.com, the public
# contact address (REQ-031/DEC-025). MAIL_FROM_NAME is the shared display name.
# Owner: update this VPS .env manually — the template is not auto-applied.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAIL_SENDER=espace@big-emotion.com
MAIL_FROM_NAME=BIG EMOTION
