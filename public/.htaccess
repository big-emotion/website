# BIG EMOTION — static export server config (Apache).
#
# Next copies everything under public/ into the export root, so this file lands
# at the web root next to index.html, 404.html and the _next/ tree.
#
# Serving model: an Apache 2.4 + PHP container behind the VPS-level Traefik,
# which terminates TLS (see docs/adr/0003 and deploy/). The <IfModule> guards
# are kept from the shared-hosting era: they cost nothing and keep this file
# safe to drop onto any Apache where a module might be missing.
#
# Deliberately NO Content-Security-Policy here: Next's static export injects an
# inline bootstrap <script>, and a strict CSP without per-build nonces/hashes
# would block it and white-screen the page. If a CSP is ever added it must be
# generated at build time with the right hashes — not hand-written in this file.


# ---------------------------------------------------------------------------
# (1) Force HTTPS  +  (2) Legacy WordPress -> single-page anchor redirects
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS.
  # TLS is terminated upstream (Traefik), so %{HTTPS} reads "off" on a request
  # that actually reached the user over HTTPS. We only redirect when BOTH the
  # local flag is off AND the forwarded-proto header is not https — this avoids
  # an infinite http<->https redirect loop behind the proxy. The target is
  # scheme-relative to keep this domain-agnostic.
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # 301s from the old Divi/WordPress URLs to the new one-page anchors.
  # [NE] (noescape) is required: without it Apache URL-encodes the "#" to "%23"
  # and the fragment never reaches the browser as a real anchor. The optional
  # "/?" tolerates the legacy trailing slash. Home "/" is intentionally left as-is.
  # Targets are absolute https:// URLs: Apache only ever sees plain HTTP behind
  # Traefik, so a relative target would 301 to http:// and force a second,
  # pointless redirect hop through the HTTPS rule above.
  RewriteRule ^contactez-nous/?$            https://%{HTTP_HOST}/#contact [R=301,L,NE]
  RewriteRule ^les-membres/?$               https://%{HTTP_HOST}/#culture [R=301,L,NE]
  RewriteRule ^case-study-mamiezi/?$        https://%{HTTP_HOST}/#cases   [R=301,L,NE]
  RewriteRule ^case-study-adolebatisseur/?$ https://%{HTTP_HOST}/#cases   [R=301,L,NE]

  # Legacy /favicon.ico requests: serve the SVG mark (we ship no .ico). Modern
  # browsers use the <link rel="icon"> in the HTML; this just stops a stray 404.
  RewriteRule ^favicon\.ico$ /icon.svg [L]
</IfModule>


# ---------------------------------------------------------------------------
# (3) Security headers (intentionally no strict CSP — see note at top)
# ---------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Stop browsers from MIME-sniffing a response away from its declared type.
  Header set X-Content-Type-Options "nosniff"

  # Send the origin (not the full path/query) on cross-origin navigations.
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Disallow framing by third-party origins (clickjacking protection).
  Header set X-Frame-Options "SAMEORIGIN"

  # Minimal Permissions-Policy: switch off powerful features the site never uses,
  # and opt out of the Topics API for GDPR hygiene.
  Header set Permissions-Policy "geolocation=(), camera=(), microphone=(), browsing-topics=()"

  # HSTS: after the first HTTPS visit, browsers refuse plain HTTP for a year, closing
  # the first-request downgrade window the HTTP->HTTPS redirect alone leaves open.
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>


# ---------------------------------------------------------------------------
# (4) Compression for text assets (woff2/png/jpg are already compressed)
# ---------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript text/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml text/xml
</IfModule>


# ---------------------------------------------------------------------------
# (5) Caching: immutable for fingerprinted assets, no-cache for HTML
# ---------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  # Flag every request under /_next/static (hashed JS/CSS chunks and the
  # self-hosted woff2 fonts in _next/static/media) as safe to cache forever.
  RewriteRule ^_next/static/ - [E=IMMUTABLE_ASSET:1]
</IfModule>

<IfModule mod_headers.c>
  # Fingerprinted assets never change under a given URL -> cache for a year.
  Header set Cache-Control "public, max-age=31536000, immutable" env=IMMUTABLE_ASSET

  # HTML is the single entry point and must always be revalidated so a redeploy
  # is picked up immediately (matches index.html served for "/" and "/approach/").
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>


# ---------------------------------------------------------------------------
# (6) Custom 404 — Next emits 404.html at the export root
# ---------------------------------------------------------------------------
ErrorDocument 404 /404.html


# ---------------------------------------------------------------------------
# (7) Generated images — Next emits these as extensionless files (out/opengraph-image,
#     out/apple-icon), so Apache can't infer the type. Force PNG for strict clients.
# ---------------------------------------------------------------------------
<FilesMatch "^(opengraph-image|apple-icon)$">
  ForceType image/png
</FilesMatch>


# ---------------------------------------------------------------------------
# (8) Preview staging copy (/preview) — never indexed
# ---------------------------------------------------------------------------
# This file is deployed verbatim to both the production root (live/.htaccess)
# and the preview copy (live/preview/.htaccess, see deploy-preview.yml), so the
# condition below matches on the absolute REQUEST_URI rather than a
# directory-relative pattern: it fires correctly from whichever copy Apache
# evaluates for a given request, and never matches outside /preview.
<IfModule mod_rewrite.c>
  RewriteCond %{REQUEST_URI} ^/preview(/|$)
  RewriteRule ^ - [E=PREVIEW_PATH:1]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex" env=PREVIEW_PATH
</IfModule>
