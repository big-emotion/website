# Espace client auth (SWBE-27)

# Secret used to sign/verify the session cookie (HMAC-SHA256). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Base URL used to build magic-link verification URLs (e.g. https://big-emotion.com).
# Falls back to the request origin in dev when unset.
PORTAL_BASE_URL=http://localhost:3000

# Transactional mail — Microsoft Graph sendMail (magic links + contact relay),
# the same tenant app the support-agent portal uses, so one set of secrets covers
# both sites. MAIL_SENDER = the licensed M365 mailbox that sends; MAIL_FROM_NAME =
# its display name. src/lib/mail.ts falls back to a dev stub when these are unset.
# GRAPH_TENANT_ID is the portal's name; AZURE_TENANT_ID is also accepted.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAIL_SENDER=
MAIL_FROM_NAME=

# Prismic (SWBE-24)
#
# The /cases routes read their case studies from Prismic at build time, so the two
# variables below are required to BUILD, not just to run: `pnpm build` fails fast
# without them rather than shipping a page with no case studies.

# Repository domain, i.e. the <name> in <name>.prismic.io.
PRISMIC_REPOSITORY_NAME=big-emotion

# Content API read token — Settings > API & Security > Repository security.
PRISMIC_ACCESS_TOKEN=

# Custom Types API write token — Settings > API & Security > Write APIs. Only the
# model-sync scripts use it (prismic:push / prismic:pull / prismic:check); the app
# itself never reads it, and it is NOT needed to build.
PRISMIC_CUSTOM_TYPES_API_TOKEN=

# Publish-webhook shared secret (SWBE-80). RUNTIME-only — the build never reads it, but
# the running server does, so it belongs in the container environment and not in a
# Docker build arg. Must match the "Secret" field of the Prismic webhook (Settings >
# Webhooks) pointing at https://<host>/api/revalidate.
#
# Prismic does not sign webhook bodies; it sends this value in the JSON payload, so it
# is a bearer credential — treat it like a password. Unset, /api/revalidate fails closed
# and rejects every caller. Generate with: openssl rand -base64 32
PRISMIC_WEBHOOK_SECRET=
