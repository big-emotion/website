# Espace client auth (SWBE-27)

# Secret used to sign/verify the session cookie (HMAC-SHA256). Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# Base URL used to build magic-link verification URLs (e.g. https://big-emotion.com).
# Falls back to the request origin in dev when unset.
PORTAL_BASE_URL=http://localhost:3000

# Transactional mail — Microsoft Graph sendMail (magic links + contact relay),
# the same tenant app the support-agent portal uses, so one set of secrets covers
# both sites. MAIL_SENDER = the licensed M365 mailbox that sends; MAIL_FROM_NAME =
# its display name. src/lib/mail.ts falls back to a dev stub when these are unset.
# GRAPH_TENANT_ID is the portal's name; AZURE_TENANT_ID is also accepted.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
MAIL_SENDER=
MAIL_FROM_NAME=
